<UserControl x:Class="FleetManagementSystem.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:viewmodels="clr-namespace:FleetManagementSystem.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance Type=viewmodels:LoginViewModel}"
             Background="#F5F7FA">
    <Grid>
        <Border Background="White" Width="380" Height="400" CornerRadius="10" 
                HorizontalAlignment="Center" VerticalAlignment="Center">
            
            <Border.Effect>
                <DropShadowEffect Color="#CCCCCC" BlurRadius="20" ShadowDepth="5" Opacity="0.5"/>
            </Border.Effect>

            <StackPanel Margin="30" VerticalAlignment="Center">
                
                <TextBlock Text="Bienvenue" FontSize="28" FontWeight="Bold" Foreground="#2C3E50" 
                           HorizontalAlignment="Center" Margin="0,0,0,10"/>
                
                <TextBlock Text="Veuillez vous authentifier" FontSize="14" Foreground="#7F8C8D" 
                           HorizontalAlignment="Center" Margin="0,0,0,40"/>

                <!-- Username Field -->
                <TextBlock Text="Nom d'utilisateur" FontSize="14" Foreground="#34495E" Margin="0,0,0,5"/>
                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" 
                         Height="40" FontSize="16" Padding="10" Margin="0,0,0,20">
                    <TextBox.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="5"/>
                            <Setter Property="BorderBrush" Value="#BDC3C7"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <!-- Password Field -->
                <!-- Note: WPF PasswordBox can't be easily bound to ViewModels conventionally without helpers, 
                     so we use an approach using code-behind or a normal TextBox for simplicity here. -->
                <TextBlock Text="Mot de passe" FontSize="14" Foreground="#34495E" Margin="0,0,0,5"/>
                <TextBox Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}" 
                         Height="40" FontSize="16" Padding="10" Margin="0,0,0,30">
                    <TextBox.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="5"/>
                            <Setter Property="BorderBrush" Value="#BDC3C7"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <!-- Login Button -->
                <Button Content="Connexion" Command="{Binding LoginCommand}" 
                        Height="45" FontSize="16" FontWeight="Bold" Foreground="White" Background="#3498DB" BorderThickness="0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>

            </StackPanel>
        </Border>
    </Grid>
</UserControl>
