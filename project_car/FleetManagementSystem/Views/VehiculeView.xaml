<UserControl x:Class="FleetManagementSystem.Views.VehiculeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:viewmodels="clr-namespace:FleetManagementSystem.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance Type=viewmodels:VehiculeViewModel}"
             Background="Transparent">
    <Grid Margin="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Gestion des Véhicules" Style="{StaticResource PageTitle}"/>
            <TextBlock Text="Suivi des affectations client-garage et informations du parc roulant." Style="{StaticResource PageSubtitle}"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource FormCardBorder}" Margin="0,0,0,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,14">
                    <TextBlock Text="Matricule" Style="{StaticResource FieldLabel}"/>
                    <TextBox Style="{StaticResource FormTextBox}"
                             Text="{Binding SelectedVehicule.Matricule, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,14">
                    <TextBlock Text="Année" Style="{StaticResource FieldLabel}"/>
                    <TextBox Style="{StaticResource FormTextBox}"
                             Text="{Binding SelectedVehicule.Annee, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,14">
                    <TextBlock Text="Marque" Style="{StaticResource FieldLabel}"/>
                    <TextBox Style="{StaticResource FormTextBox}"
                             Text="{Binding SelectedVehicule.Marque, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,14">
                    <TextBlock Text="Modèle" Style="{StaticResource FieldLabel}"/>
                    <TextBox Style="{StaticResource FormTextBox}"
                             Text="{Binding SelectedVehicule.Modele, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,8">
                    <TextBlock Text="Client" Style="{StaticResource FieldLabel}"/>
                    <ComboBox Style="{StaticResource FormComboBox}"
                              ItemsSource="{Binding Clients}"
                              SelectedValue="{Binding SelectedVehicule.ClientId, UpdateSourceTrigger=PropertyChanged}"
                              SelectedValuePath="Id">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock>
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0} {1}">
                                            <Binding Path="Nom"/>
                                            <Binding Path="Prenom"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,0,8">
                    <TextBlock Text="Garage" Style="{StaticResource FieldLabel}"/>
                    <ComboBox Style="{StaticResource FormComboBox}"
                              ItemsSource="{Binding Garages}"
                              SelectedValue="{Binding SelectedVehicule.GarageId, UpdateSourceTrigger=PropertyChanged}"
                              SelectedValuePath="Id"
                              DisplayMemberPath="Nom"/>
                </StackPanel>

                <StackPanel Grid.Row="3" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                    <Button Content="Nouveau" Command="{Binding ClearCommand}" Style="{StaticResource NeutralActionButton}" Width="112" Margin="0,0,10,0"/>
                    <Button Content="Ajouter" Command="{Binding AddCommand}" Style="{StaticResource SuccessActionButton}" Width="112" Margin="0,0,10,0"/>
                    <Button Content="Modifier" Command="{Binding UpdateCommand}" Style="{StaticResource PrimaryActionButton}" Width="112" Margin="0,0,10,0"/>
                    <Button Content="Supprimer" Command="{Binding DeleteCommand}" Style="{StaticResource DangerActionButton}" Width="112"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource DataCardBorder}">
            <DataGrid ItemsSource="{Binding Vehicules}" SelectedItem="{Binding SelectedVehicule}" AutoGenerateColumns="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                    <DataGridTextColumn Header="Matricule" Binding="{Binding Matricule}" Width="130"/>
                    <DataGridTextColumn Header="Marque" Binding="{Binding Marque}" Width="170"/>
                    <DataGridTextColumn Header="Modèle" Binding="{Binding Modele}" Width="170"/>
                    <DataGridTextColumn Header="Année" Binding="{Binding Annee}" Width="95"/>
                    <DataGridTextColumn Header="Client" Binding="{Binding Client.Nom}" Width="160"/>
                    <DataGridTextColumn Header="Garage" Binding="{Binding Garage.Nom}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
