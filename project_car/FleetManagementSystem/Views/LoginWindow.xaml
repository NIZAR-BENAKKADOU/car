<Window x:Class="FleetManagementSystem.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:FleetManagementSystem.ViewModels"
        mc:Ignorable="d"
        Title="Fleet Management — Connexion"
        Height="560" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>

        <!-- Input field style -->
        <Style x:Key="InputStyle" TargetType="Control">
            <Setter Property="Height" Value="44"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="BorderBrush" Value="#DDE3ED"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- Label style -->
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#4A5568"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <!-- Primary button style -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="46"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2980B9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1F6391"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#AEC6CF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Close button style -->
        <Style x:Key="CloseButton" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E74C3C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- Outer shadow container -->
    <Border CornerRadius="14" Background="White">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="30" ShadowDepth="4" Opacity="0.20"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <!-- Header band -->
                <RowDefinition Height="160"/>
                <!-- Form area -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ═══════════════════  HEADER  ═══════════════════ -->
            <Border Grid.Row="0" CornerRadius="14,14,0,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1A2980" Offset="0"/>
                        <GradientStop Color="#26D0CE" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid>
                    <!-- Drag to move -->
                    <Grid MouseLeftButtonDown="Header_MouseLeftButtonDown"/>

                    <!-- Close button -->
                    <Button Style="{StaticResource CloseButton}"
                            Content="✕"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,10,10,0"
                            Click="CloseButton_Click"/>

                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,10,0,0">

                        <!-- Car icon (Unicode) -->
                        <Border Width="64" Height="64" CornerRadius="32"
                                Background="#FFFFFF22"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,10">
                            <TextBlock Text="🚗"
                                       FontSize="32"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <TextBlock Text="Fleet Manager"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="Système de Gestion du Parc Automobile"
                                   FontSize="11" Foreground="#CCECFF"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══════════════════  FORM  ═══════════════════ -->
            <StackPanel Grid.Row="1" Margin="36,28,36,28">

                <!-- Username -->
                <TextBlock Text="Nom d'utilisateur" Style="{StaticResource LabelStyle}"/>
                <Grid Margin="0,0,0,18">
                    <TextBox x:Name="UsernameBox"
                             Style="{StaticResource InputStyle}"
                             Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                             KeyDown="Input_KeyDown">
                        <TextBox.Template>
                            <ControlTemplate TargetType="TextBox">
                                <Border x:Name="border"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="8">
                                    <ScrollViewer x:Name="PART_ContentHost"
                                                  Margin="{TemplateBinding Padding}"
                                                  VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsFocused" Value="True">
                                        <Setter TargetName="border" Property="BorderBrush" Value="#3498DB"/>
                                        <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </TextBox.Template>
                    </TextBox>
                </Grid>

                <!-- Password -->
                <TextBlock Text="Mot de passe" Style="{StaticResource LabelStyle}"/>
                <Grid Margin="0,0,0,10">
                    <PasswordBox x:Name="PasswordBox"
                                 Style="{StaticResource InputStyle}"
                                 PasswordChar="●"
                                 KeyDown="Input_KeyDown">
                        <PasswordBox.Template>
                            <ControlTemplate TargetType="PasswordBox">
                                <Border x:Name="border"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="8">
                                    <ScrollViewer x:Name="PART_ContentHost"
                                                  Margin="{TemplateBinding Padding}"
                                                  VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsFocused" Value="True">
                                        <Setter TargetName="border" Property="BorderBrush" Value="#3498DB"/>
                                        <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </PasswordBox.Template>
                    </PasswordBox>
                </Grid>

                <!-- Error message -->
                <TextBlock x:Name="ErrorText"
                           Foreground="#E74C3C"
                           FontSize="12"
                           Margin="0,0,0,18"
                           TextWrapping="Wrap"
                           Visibility="Collapsed"/>

                <!-- Login button -->
                <Button Content="Se connecter"
                        Style="{StaticResource PrimaryButton}"
                        Click="LoginButton_Click"/>

                <!-- Hint -->
                <TextBlock Text="💡  Identifiants : admin / admin"
                           FontSize="11"
                           Foreground="#A0AEC0"
                           HorizontalAlignment="Center"
                           Margin="0,14,0,0"/>

            </StackPanel>
        </Grid>
    </Border>
</Window>
