<Window x:Class="FleetManagementSystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FleetManagementSystem"
        xmlns:views="clr-namespace:FleetManagementSystem.Views"
        xmlns:viewmodels="clr-namespace:FleetManagementSystem.ViewModels"
        mc:Ignorable="d"
        Title="Fleet Management System" Height="720" Width="1180"
        WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <!-- DataTemplates to link ViewModels to Views -->
        <DataTemplate DataType="{x:Type viewmodels:ClientViewModel}">
            <views:ClientView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:GarageViewModel}">
            <views:GarageView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:VehiculeViewModel}">
            <views:VehiculeView />
        </DataTemplate>
    </Window.Resources>

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar Navigation -->
        <Border Grid.Column="0"
                Margin="16,16,12,16"
                Background="{StaticResource SidebarGradientBrush}"
                CornerRadius="20">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="24" ShadowDepth="6" Opacity="0.18"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="18,22,18,10">
                    <Border Background="#26FFFFFF" CornerRadius="12" Padding="14,12">
                        <StackPanel>
                            <TextBlock Text="Fleet Manager" Style="{StaticResource SidebarBrandTitle}"/>
                            <TextBlock Text="Control Center" Style="{StaticResource SidebarBrandSubtitle}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="18,8,18,0">
                    <Button Content="Clients" Style="{StaticResource SidebarNavButton}" Command="{Binding NavigateToClientsCommand}"/>
                    <Button Content="Garages" Style="{StaticResource SidebarNavButton}" Command="{Binding NavigateToGaragesCommand}"/>
                    <Button Content="Véhicules" Style="{StaticResource SidebarNavButton}" Command="{Binding NavigateToVehiculesCommand}"/>
                </StackPanel>

                <TextBlock Grid.Row="2"
                           Margin="24,10,24,20"
                           Text="Management Suite"
                           FontSize="11"
                           Foreground="#BFE9FF"/>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Column="1" Margin="0,16,16,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource AccentHeaderBrush}"
                    CornerRadius="16"
                    Padding="20,16"
                    Margin="0,0,0,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Gestion du Parc Automobile" Foreground="White" FontSize="24" FontWeight="Bold"/>
                        <TextBlock Text="Operations quotidiennes: clients, garages et vehicules" Foreground="#EAF9FF" FontSize="12" Margin="0,2,0,0"/>
                    </StackPanel>

                    <Border Grid.Column="1" Background="#2EFFFFFF" CornerRadius="10" Padding="12,8" VerticalAlignment="Center">
                        <TextBlock Text="Dashboard" Foreground="White" FontWeight="SemiBold" FontSize="12"/>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="1" Style="{StaticResource ShellContentBorder}">
                <!-- This ContentControl binds to the CurrentViewModel from MainViewModel.
                     WPF automatically resolves the View using the DataTemplates above. -->
                <ContentControl Content="{Binding CurrentViewModel}" />
            </Border>
        </Grid>
    </Grid>
</Window>
